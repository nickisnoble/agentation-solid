{
  "name": "agentation-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter agentation-solid watch & pnpm --filter agentation-solid-example dev",
    "build": "pnpm --filter agentation-solid build",
    "example": "pnpm --filter agentation-solid-example dev",
    "pack": "cd package && pnpm pack",
    "ship": "pnpm --filter agentation-solid ship"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
