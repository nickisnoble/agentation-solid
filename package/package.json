{
  "name": "agentation-solid",
  "version": "0.1.0",
  "description": "Visual feedback for AI coding agents — SolidJS edition",
  "sideEffects": false,
  "license": "PolyForm-Shield-1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "pnpm build && pnpm watch",
    "ship": "npm version patch --no-git-tag-version && pnpm build && npm publish --access public",
    "ship:minor": "npm version minor --no-git-tag-version && pnpm build && npm publish --access public",
    "ship:major": "npm version major --no-git-tag-version && pnpm build && npm publish --access public"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild-sass-plugin": "^3.6.0",
    "postcss": "^8.5.6",
    "postcss-modules": "^6.0.1",
    "sass": "^1.97.2",
    "solid-js": "^1.9.0",
    "tsup": "^8.0.0",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.0.0",
    "vite-plugin-solid": "^2.10.0"
  }
}
